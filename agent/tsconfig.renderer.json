{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist/renderer",
    "rootDir": "src/renderer"
  },
  "include": ["src/renderer/**/*.ts"],
  "exclude": ["src/renderer/**/*.test.ts"]
}
