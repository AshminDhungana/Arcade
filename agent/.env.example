# Arcade Agent — local environment overrides
#
# Emergency master PIN used to unlock the kiosk overlay when the agent cannot
# reach the server. It is hashed at enrollment with Argon2id (params match
# tools/keygen/generate_keys.py); the plaintext is never written to disk — only
# the hash lands in agent.config.json.
#
# Resolution order: ARCADE_MASTER_PIN  >  built-in default (1928).
# Set to a blank value to disable the emergency master PIN entirely.
#
# Copy this file to `.env` and edit, or export the variable in your environment.
ARCADE_MASTER_PIN=1928
