    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "jsdom": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "sharp": "^0.35.2",
    "systeminformation": "^5.31.11"
  }
