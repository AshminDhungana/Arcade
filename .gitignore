# ===============================
# Arcade — Licensing / Secrets (R-05)
# ===============================
# Ed25519 keygen private key — NEVER committed (lives out-of-band on seller machine)
tools/keygen/private_key.pem
private_key.pem
*.pem
# License files (issued per-customer, placed at runtime, never in VCS)
license.key
*.license
# Generic private key material
*.key
private_key*

# Runtime config (generated by setup wizard — contains agent_secrets + PIN hashes)
arcade.config.json
agent/agent.config.json

# Runtime databases (SQLite production + dev, with WAL/SHM sidecar files)
*.db
*.db-shm
*.db-wal

# Backup output from BackupService (nightly SQLite copies)
backups/